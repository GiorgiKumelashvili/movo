---
import '../styles/components/omni-search.css';
---

<div
  id="omni-overlay"
  class="omni-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
  aria-hidden="true"
>
  <div class="omni-overlay__inner">
    <div class="omni-overlay__header">
      <svg class="omni-overlay__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.35-4.35" />
      </svg>
      <input
        id="omni-input"
        class="omni-overlay__input"
        type="search"
        placeholder="Search movies, series, genres..."
        autocomplete="off"
        aria-label="Search"
      />
      <button id="omni-close" class="omni-overlay__esc" aria-label="Close search">ESC</button>
    </div>
    <div class="omni-overlay__divider"></div>

    <div class="omni-overlay__body">
      <p id="omni-section-label" class="omni-overlay__section-label">Popular right now</p>
      <div id="omni-results" class="omni-overlay__results" role="list" aria-live="polite"></div>
      <div id="omni-empty" class="omni-overlay__empty" hidden>
        <div class="omni-empty__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.35-4.35" />
            <line x1="8" y1="11" x2="14" y2="11" />
          </svg>
        </div>
        <p id="omni-empty-msg" class="omni-empty__title">No results</p>
        <p class="omni-empty__hint">Try a different title or genre</p>
      </div>
    </div>
  </div>
</div>

<script>
  import { initOmniSearch } from '../scripts/omniSearch';
  initOmniSearch();
</script>
