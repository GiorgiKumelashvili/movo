---
import Layout from '../components/Layout.astro';
import VideoPlayer from '../components/VideoPlayer.astro';
import SeasonSelector from '../components/SeasonSelector.astro';
import { getBySlug, getById } from '../data/shows';
import '../styles/pages/show.css';

// Read params server-side to pre-render the correct show
const params = Astro.url.searchParams;
const id = params.get('id') ?? undefined;
const titleSlug = params.get('title') ?? undefined;

const show = id ? getById(id) : titleSlug ? getBySlug(titleSlug) : undefined;

// If no show found at build time, we still render the shell — client script handles redirect
const seasonParam = Number(params.get('season') ?? 1);
const episodeParam = Number(params.get('episode') ?? 1);

const currentSeason = isNaN(seasonParam) || seasonParam < 1 ? 1 : seasonParam;
const currentEpisode = isNaN(episodeParam) || episodeParam < 1 ? 1 : episodeParam;

// For series: resolve the video src from season/episode params
function resolveVideoSrc(): string {
  if (!show) return '/videos/sample.mp4';
  if (show.type === 'movie') return show.videoSrc ?? '/videos/sample.mp4';
  const season = show.seasons?.find((s) => s.season === currentSeason);
  const episode = season?.episodes.find((e) => e.episode === currentEpisode);
  return episode?.videoSrc ?? show.seasons?.[0]?.episodes?.[0]?.videoSrc ?? '/videos/sample.mp4';
}

function resolveVideoTitle(): string {
  if (!show) return '';
  if (show.type === 'movie') return show.title;
  const season = show.seasons?.find((s) => s.season === currentSeason);
  const episode = season?.episodes.find((e) => e.episode === currentEpisode);
  return episode ? `S${currentSeason}E${currentEpisode}: ${episode.title}` : show.title;
}

const videoSrc = resolveVideoSrc();
const videoTitle = resolveVideoTitle();
---

<Layout title={show?.title ?? 'Show'} description={show?.description}>
  {
    show ? (
      <main class="show-page" data-focusable>
        <div class="show-page__backdrop-wrap">
          <img
            class="show-page__backdrop"
            src={show.backdrop}
            alt={`${show.title} backdrop`}
            fetchpriority="high"
            width="1280"
            height="720"
          />
          <div class="show-page__backdrop-overlay" />
        </div>

        <div class="show-page__body">
          <div class="show-page__top">
            <img
              class="show-page__poster"
              src={show.poster}
              alt={`${show.title} poster`}
              width="300"
              height="450"
            />
            <div class="show-page__info">
              <div class="show-page__type-badge">{show.type}</div>
              <h1 class="show-page__title">{show.title}</h1>

              <div class="show-page__meta-row">
                <span class="show-page__rating" aria-label={`IMDB ${show.rating}`}>
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                  </svg>
                  {show.rating.toFixed(1)}
                </span>
                <span class="show-page__year">{show.year}</span>
                {show.runtime && <span class="show-page__runtime">{show.runtime}</span>}
              </div>

              <div class="show-page__tags">
                {show.tags.map((tag) => (
                  <span class="show-page__tag">{tag}</span>
                ))}
              </div>

              <div class="show-page__genres">
                {show.genre.map((g) => (
                  <span class="show-page__genre">{g}</span>
                ))}
              </div>

              <p class="show-page__description">{show.description}</p>

              <div class="show-page__actions">
                <button
                  class="show-page__btn show-page__btn--play"
                  id="play-btn"
                  aria-label={`Play ${show.title}`}
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                  Play
                </button>
                <button
                  class="show-page__btn show-page__btn--save"
                  id="save-btn"
                  aria-label="Save to watchlist"
                  data-slug={show.slug}
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z" />
                  </svg>
                  Save
                </button>
              </div>
            </div>
          </div>

          <!-- Player -->
          <div class="show-page__player-section" id="player-section">
            <VideoPlayer
              src={videoSrc}
              poster={show.backdrop}
              title={videoTitle}
              showSlug={show.slug}
              showType={show.type}
              season={show.type === 'series' ? currentSeason : undefined}
              episode={show.type === 'series' ? currentEpisode : undefined}
            />
          </div>

          <!-- Season selector for series -->
          {show.type === 'series' && show.seasons && (
            <SeasonSelector
              seasons={show.seasons}
              currentSeason={currentSeason}
              currentEpisode={currentEpisode}
            />
          )}
        </div>
      </main>
    ) : (
      <!-- Shell for client-side redirect when params are missing at build time -->
      <div id="show-redirect-shell" style="display:none" />
    )
  }

  <script>
    import { initSaved } from '../scripts/saved';

    // Init save button
    initSaved();

    // Play button scrolls to player
    const playBtn = document.getElementById('play-btn');
    const playerSection = document.getElementById('player-section');
    const playerVideo = document.getElementById('player-video') as HTMLVideoElement | null;

    playBtn?.addEventListener('click', () => {
      playerSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setTimeout(() => void playerVideo?.play(), 400);
    });
  </script>
</Layout>
