---
import '../styles/components/video-player.css';

interface Props {
  src: string;
  poster?: string;
  title: string;
  showSlug: string;
  showType: string;
  season?: number;
  episode?: number;
}

const { src, poster, title, showSlug, showType, season, episode } = Astro.props;
---

<div
  class="player-wrap"
  id="player-wrap"
  data-slug={showSlug}
  data-type={showType}
  data-season={season}
  data-episode={episode}
>
  <video
    id="player-video"
    class="player-video"
    src={src}
    poster={poster}
    preload="metadata"
    playsinline
    aria-label={`Video: ${title}`}
  ></video>

  <div class="player-controls" id="player-controls">
    <div class="player-controls__title" id="player-title">{title}</div>

    <div
      class="player-progress"
      id="player-progress"
      role="slider"
      aria-label="Seek"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      tabindex="0"
    >
      <div class="player-progress__fill" id="player-progress-fill"></div>
      <div class="player-progress__thumb" id="player-progress-thumb"></div>
    </div>

    <div class="player-controls__row">
      <button class="player-btn" id="player-play" aria-label="Play">
        <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
      </button>

      <div class="player-volume-wrap">
        <button class="player-btn" id="player-mute" aria-label="Mute">
          <svg viewBox="0 0 24 24">
            <path
              d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"
            />
          </svg>
        </button>
        <input
          class="player-volume-slider"
          id="player-volume"
          type="range"
          min="0"
          max="1"
          step="0.05"
          value="1"
          aria-label="Volume"
        />
      </div>

      <span class="player-time" id="player-time" aria-live="off">0:00 / 0:00</span>

      <div class="player-spacer"></div>

      <button class="player-btn" id="player-fullscreen" aria-label="Fullscreen">
        <svg viewBox="0 0 24 24">
          <path
            d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"
          />
        </svg>
      </button>
    </div>
  </div>

  <!-- Error state (hidden by default) -->
  <div class="player-error" id="player-error" style="display:none">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
    </svg>
    <p>Video unavailable — demo only</p>
  </div>
</div>

<script>
  import { initVideoPlayer } from '../scripts/videoPlayer';
  initVideoPlayer();
</script>
