---
export const prerender = false;

import Layout from '../../components/Layout.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import SeasonSelector from '../../components/SeasonSelector.astro';
import { getMovieDetail, getTvDetail } from '../../lib/tmdb';
import type { Show } from '../../data/shows';
import '../../styles/pages/show.css';

const { slug } = Astro.params;

function parseSlug(s: string): { type: 'movie' | 'series'; tmdbId: number } | null {
  const movieMatch = /^movie-(\d+)$/.exec(s);
  if (movieMatch?.[1]) return { type: 'movie', tmdbId: Number(movieMatch[1]) };
  const tvMatch = /^series-(\d+)$/.exec(s);
  if (tvMatch?.[1]) return { type: 'series', tmdbId: Number(tvMatch[1]) };
  return null;
}

const parsed = slug ? parseSlug(slug) : null;
if (!parsed) return Astro.redirect('/404');

let show: Show;
try {
  show = parsed.type === 'movie'
    ? await getMovieDetail(parsed.tmdbId)
    : await getTvDetail(parsed.tmdbId);
} catch {
  return Astro.redirect('/404');
}

const currentSeason = 1;
const currentEpisode = 1;
---

<Layout title={show.title} description={show.description} shows={[show]}>
  <main class="show-page" data-focusable>
    <div class="show-page__backdrop-wrap">
      <img
        class="show-page__backdrop"
        src={show.backdrop}
        alt={`${show.title} backdrop`}
        fetchpriority="high"
        width="1280"
        height="720"
      />
      <div class="show-page__backdrop-overlay" />
    </div>

    <div class="show-page__body">
      <div class="show-page__top">
        <img
          class="show-page__poster"
          src={show.poster}
          alt={`${show.title} poster`}
          width="300"
          height="450"
        />
        <div class="show-page__info">
          <div class="show-page__type-badge">{show.type}</div>
          <h1 class="show-page__title">{show.title}</h1>

          <div class="show-page__meta-row">
            <span class="show-page__rating" aria-label={`Rating ${show.rating}`}>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
              </svg>
              {show.rating.toFixed(1)}
            </span>
            <span class="show-page__year">{show.year}</span>
            {show.runtime && <span class="show-page__runtime">{show.runtime}</span>}
          </div>

          <div class="show-page__tags">
            {show.tags.map((tag) => (
              <span class="show-page__tag">{tag}</span>
            ))}
          </div>

          <div class="show-page__genres">
            {show.genre.map((g) => (
              <span class="show-page__genre">{g}</span>
            ))}
          </div>

          <p class="show-page__description">{show.description}</p>

          <div class="show-page__actions">
            <button
              class="show-page__btn show-page__btn--play"
              id="play-btn"
              aria-label={`Play ${show.title}`}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M8 5v14l11-7z" />
              </svg>
              Play
            </button>
            <button
              class="show-page__btn show-page__btn--save"
              id="save-btn"
              aria-label="Save to watchlist"
              data-slug={show.slug}
              data-title={show.title}
              data-poster={show.poster}
              data-year={show.year}
              data-showtype={show.type}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z" />
              </svg>
              Save
            </button>
          </div>
        </div>
      </div>

      <div class="show-page__player-section" id="player-section">
        {show.type === 'movie' && (
          <VideoPlayer
            tmdbId={show.tmdbId ?? parsed.tmdbId}
            showType={show.type}
            title={show.title}
            showSlug={show.slug}
          />
        )}
        {show.type === 'series' && (
          <VideoPlayer
            tmdbId={show.tmdbId ?? parsed.tmdbId}
            showType={show.type}
            title={show.title}
            showSlug={show.slug}
            season={currentSeason}
            episode={currentEpisode}
          />
        )}
      </div>

      {show.type === 'series' && show.seasons && show.seasons.length > 0 && (
        <SeasonSelector
          seasons={show.seasons}
          currentSeason={currentSeason}
          currentEpisode={currentEpisode}
        />
      )}
    </div>
  </main>

  <script>
    import { initSaved } from '../../scripts/saved';

    initSaved();

    const playBtn = document.getElementById('play-btn');
    const playerSection = document.getElementById('player-section');

    playBtn?.addEventListener('click', () => {
      playerSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</Layout>
