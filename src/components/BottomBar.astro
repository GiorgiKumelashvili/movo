---
import '../styles/components/bottom-bar.css';

const currentPath = Astro.url.pathname;
---

<nav class="bottom-bar" aria-label="Main navigation">
  <a
    href="/"
    class:list={['bottom-bar__item', { active: currentPath === '/' }]}
    aria-label="Home"
  >
    <span class="bottom-bar__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
      </svg>
    </span>
    <span class="bottom-bar__label">Home</span>
  </a>

  <button
    id="search-toggle"
    class="bottom-bar__item"
    aria-label="Open search"
    aria-expanded="false"
    aria-controls="omni-overlay"
  >
    <span class="bottom-bar__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
        />
      </svg>
    </span>
    <span class="bottom-bar__label">Search</span>
  </button>

  <a
    href="/profile#saved"
    class:list={['bottom-bar__item', { active: currentPath === '/profile' }]}
    aria-label="Saved shows"
  >
    <span class="bottom-bar__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z" />
      </svg>
    </span>
    <span class="bottom-bar__label">Saved</span>
  </a>

  <a
    href="/profile"
    class:list={['bottom-bar__item', { active: currentPath === '/profile' }]}
    aria-label="Profile"
  >
    <span class="bottom-bar__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
        />
      </svg>
    </span>
    <span class="bottom-bar__label">Profile</span>
  </a>
</nav>
