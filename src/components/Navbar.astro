---
import '../styles/components/navbar.css';
---

<header class="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__brand">Movo</a>

    <div class="navbar__actions">
      <button id="search-toggle" class="navbar__search-btn" aria-label="Open search" aria-expanded="false" aria-controls="omni-overlay">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" />
        </svg>
      </button>

      <div class="navbar__profile-wrap">
        <button
          id="profile-toggle"
          class="navbar__profile-btn"
          aria-label="Profile menu"
          aria-expanded="false"
          aria-controls="profile-dropdown"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
          </svg>
          Profile
          <svg class="navbar__chevron" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 10l5 5 5-5z" />
          </svg>
        </button>

        <div id="profile-dropdown" class="navbar__dropdown" hidden>
          <a href="/profile" class="navbar__dropdown-item">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
            </svg>
            My Profile
          </a>
          <a href="/saved" class="navbar__dropdown-item">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2z" />
            </svg>
            Saved
          </a>
          <a href="/settings" class="navbar__dropdown-item">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" />
            </svg>
            Settings
          </a>
          <div class="navbar__dropdown-divider"></div>
          <button id="signout-btn" class="navbar__dropdown-item">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
            </svg>
            Sign Out
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('profile-toggle') as HTMLButtonElement | null;
  const dropdown = document.getElementById('profile-dropdown') as HTMLDivElement | null;

  if (toggle && dropdown) {
    function openDropdown(): void {
      dropdown!.hidden = false;
      toggle!.setAttribute('aria-expanded', 'true');
    }

    function closeDropdown(): void {
      dropdown!.hidden = true;
      toggle!.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.hidden ? openDropdown() : closeDropdown();
    });

    document.addEventListener('click', (e) => {
      if (!dropdown.hidden && !dropdown.contains(e.target as Node) && e.target !== toggle) {
        closeDropdown();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !dropdown.hidden) {
        closeDropdown();
        toggle.focus();
      }
    });

    document.getElementById('signout-btn')?.addEventListener('click', () => {
      closeDropdown();
    });
  }
</script>
