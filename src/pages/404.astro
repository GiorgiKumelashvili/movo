---
import Layout from '../components/Layout.astro';
import '../styles/pages/404.css';
---

<Layout title="Not Found">
  <main class="not-found">
    <div class="not-found__code" aria-hidden="true">404</div>
    <h1 class="not-found__title">Title Not Found</h1>
    <p class="not-found__desc">
      The page or title you're looking for may have been moved, removed, or never existed.
    </p>
    <a href="/" class="not-found__link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" width="18" height="18">
        <path d="M19 12H5M12 5l-7 7 7 7" />
      </svg>
      Back to home
    </a>
  </main>
</Layout>
