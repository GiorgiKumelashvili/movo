---
import '../styles/components/navbar.css';

---

<header class="navbar" id="navbar">
  <div class="navbar__inner">
    <div class="navbar__left">
      <a href="/" class="navbar__brand" aria-label="Movo home">
        <span class="navbar__dot" aria-hidden="true"></span>
        MOVO
      </a>
    </div>

    <div class="navbar__actions">
      <button id="search-toggle" class="navbar__search-pill" aria-label="Open search" aria-expanded="false" aria-controls="omni-overlay">
        <svg class="navbar__search-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
        <span class="navbar__search-text">Search</span>
        <kbd class="navbar__key">/</kbd>
      </button>

      <div class="navbar__profile-wrap">
        <button
          id="profile-toggle"
          class="navbar__avatar"
          aria-label="Profile menu"
          aria-expanded="false"
          aria-controls="profile-dropdown"
        >
          AR
        </button>

        <div id="profile-dropdown" class="navbar__dropdown" hidden>
          <a href="/profile" class="navbar__dropdown-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="8" r="4" />
              <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" />
            </svg>
            My Profile
          </a>
          <a href="/saved" class="navbar__dropdown-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
            </svg>
            My List
          </a>
          <a href="/settings" class="navbar__dropdown-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="3" />
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
            </svg>
            Settings
          </a>
          <div class="navbar__dropdown-divider"></div>
          <button id="signout-btn" class="navbar__dropdown-item navbar__dropdown-item--danger">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
              <polyline points="16 17 21 12 16 7" />
              <line x1="21" y1="12" x2="9" y2="12" />
            </svg>
            Sign Out
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('profile-toggle') as HTMLButtonElement | null;
  const dropdown = document.getElementById('profile-dropdown') as HTMLDivElement | null;
  const navbar = document.getElementById('navbar') as HTMLElement | null;

  // Scroll transparency
  if (navbar) {
    const update = () => {
      if (window.scrollY > 40) {
        navbar.classList.add('navbar--scrolled');
      } else {
        navbar.classList.remove('navbar--scrolled');
      }
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }

  if (toggle && dropdown) {
    function openDropdown(): void {
      dropdown!.hidden = false;
      toggle!.setAttribute('aria-expanded', 'true');
    }

    function closeDropdown(): void {
      dropdown!.hidden = true;
      toggle!.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown.hidden ? openDropdown() : closeDropdown();
    });

    document.addEventListener('click', (e) => {
      if (!dropdown.hidden && !dropdown.contains(e.target as Node) && e.target !== toggle) {
        closeDropdown();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !dropdown.hidden) {
        closeDropdown();
        toggle.focus();
      }
    });

    document.getElementById('signout-btn')?.addEventListener('click', () => {
      closeDropdown();
    });
  }
</script>
