---
import '../styles/global.css';
import Navbar from './Navbar.astro';
import OmniSearch from './OmniSearch.astro';
import type { Show } from '../data/shows';

interface Props {
  title: string;
  description?: string;
  shows?: Show[];
}

const { title, description = 'Stream movies and series on Movo', shows = [] } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Movo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar />
    <slot />
    <OmniSearch />

    <!-- Data island: makes all shows available to client scripts -->
    <script type="application/json" id="shows-data" set:html={JSON.stringify(shows)}></script>

    <script is:inline>
      var el = document.getElementById('shows-data');
      if (el && el.textContent) {
        window.__SHOWS__ = JSON.parse(el.textContent);
      }
    </script>

    <script>
      import { initTvNav } from '../scripts/tvNav';
      initTvNav();
    </script>
  </body>
</html>
